@startuml
title Diagrama de Atividade - Lógica de Notificação do Atendente

start

:Identifica o atendente que está vinculado ao chamado;
:Busca as preferências de comunicação do atendente (Painel Web, E-mail ou Push);

partition "Construção do Alerta" {
  :Monta a mensagem de notificação com os dados básicos;
  note right
    Inclui: Número do chamado, nível de urgência,
    setor de origem e a mensagem inicial.
  end note
}

if (O atendente está com o sistema aberto (Online)?) then (sim)
  :Dispara um alerta visual instantâneo (Pop-up/Banner) no painel do atendente;
  :Emite um aviso sonoro de "Novo Chamado na Fila";
else (não)
  :Envia um e-mail de alerta com o resumo do chamado e o link de acesso direto;
endif

:Registra o envio da notificação no histórico para controle de entrega;

stop
@enduml